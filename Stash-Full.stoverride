rules:
  - RULE-SET,claude-fixed,CLAUDE-FIXED
  - RULE-SET,google-fixed,Google-FIXED
  - RULE-SET,ai1,✨ AI1
  - RULE-SET,ai2,✨ AI2
  - RULE-SET,github,📘 GitHub
  - RULE-SET,tiktok,👯‍♂️ TikTok
  - RULE-SET,telegram,🙋 Telegram
  - RULE-SET,twitterx,🕊️ Twitter(X)
  - RULE-SET,facebook,🗣️ Facebook
  - RULE-SET,amazon,🌳 Amazon
  - RULE-SET,apple,🍎 Apple
  - RULE-SET,microsoft,Ⓜ️ Microsoft
  - RULE-SET,steam,🎮 Steam
  - RULE-SET,epic,🕹️ Game
  - RULE-SET,ea,🕹️ Game
  - RULE-SET,blizzard,🕹️ Game
  - RULE-SET,ubi,🕹️ Game
  - RULE-SET,sony,🕹️ Game
  - RULE-SET,nintendo,🕹️ Game

name: Stash Full Override
desc: Add custom proxy groups and rules on top of a Stash-managed subscription.

proxy-groups:
  - name: CLAUDE-FIXED
    type: select
    proxies:
      - 美国-手动

  - name: Google-FIXED
    type: select
    proxies:
      - 美国-手动

  - name: ✨ AI1
    type: select
    proxies:
      - 美国-手动

  - name: ✨ AI2
    type: select
    proxies:
      - 美国-手动

  - name: 📘 GitHub
    type: select
    proxies:
      - DIRECT
      - 所有-手动
      - 所有-自动
      - 港台日新韩-自动
      - 台日新韩-自动
      - 香港-自动
      - 台湾-自动
      - 日本-自动
      - 新加坡-自动
      - 韩国-自动
      - 美国-自动
      - 其他-自动
      - REJECT

  - name: 👯‍♂️ TikTok

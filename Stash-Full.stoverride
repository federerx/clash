    type: select
    proxies:
      - DIRECT
      - 所有-手动
      - 所有-自动
      - 港台日新韩-自动
      - 台日新韩-自动
      - 香港-自动
      - 台湾-自动
      - 日本-自动
      - 新加坡-自动
      - 韩国-自动
      - 美国-自动
      - 其他-自动
      - REJECT

  - name: 所有-手动
    type: select
    include-all: true

  - name: 所有-自动
    type: url-test
    include-all: true
    url: http://www.gstatic.com/generate_204
    interval: 600

  - name: 港台日新韩-自动
    type: url-test
    include-all: true
    filter: '广港|广台|广日|广新|广韩|香港|HK|Hong Kong|🇭🇰|HongKong|台湾|TW|Tai Wan|🇹🇼|TaiWan|Taiwan|日本|JP|川日|东京|大阪|泉日|埼玉|沪日|深日|🇯🇵|Japan|新加坡|SG|坡|狮城|🇸🇬|Singapore|韩国|KR|首尔|春川|🇰🇷|Korea'
    url: http://www.gstatic.com/generate_204
    interval: 600

  - name: 台日新韩-自动
    type: url-test
    include-all: true
    filter: '广台|广日|广新|广韩|台湾|TW|Tai Wan|Taiwan|🇹🇼|TaiWan|日本|JP|川日|东京|大阪|泉日|埼玉|沪日|深日|🇯🇵|Japan|新加坡|SG|坡|狮城|🇸🇬|Singapore|韩国|KR|首尔|春川|🇰🇷|Korea'
    url: http://www.gstatic.com/generate_204
    interval: 600

  - name: 香港-自动
    type: url-test
    include-all: true
    filter: '广港|香港|HK|Hong Kong|🇭🇰|HongKong'
    url: http://www.gstatic.com/generate_204
    interval: 600

  - name: 台湾-自动
    type: url-test
    include-all: true
    filter: '广台|台湾|台灣|TW|Tai Wan|🇹🇼|TaiWan|Taiwan'
    url: http://www.gstatic.com/generate_204
    interval: 600

  - name: 日本-自动
    type: url-test
    include-all: true
    filter: '广日|日本|JP|川日|东京|大阪|泉日|埼玉|沪日|深日|🇯🇵|Japan'
    url: http://www.gstatic.com/generate_204
    interval: 600

  - name: 新加坡-自动
    type: url-test
    include-all: true
    filter: '广新|新加坡|SG|坡|狮城|🇸🇬|Singapore'
    url: http://www.gstatic.com/generate_204
    interval: 600

  - name: 韩国-自动
    type: url-test
    include-all: true
    filter: '广韩|韩国|韓國|KR|首尔|春川|🇰🇷|Korea'
    url: http://www.gstatic.com/generate_204
    interval: 600

  - name: 美国-自动
    type: url-test
    include-all: true
    filter: '广美|美国|美國|USA|United States|America|(^|[^A-Z])US([^A-Z]|$)|纽约|波特兰|达拉斯|俄勒冈|凤凰城|费利蒙|硅谷|拉斯维加斯|洛杉矶|圣何塞|圣克拉拉|西雅图|芝加哥|🇺🇸'
    url: http://www.gstatic.com/generate_204
    interval: 600

  - name: 美国-手动
    type: select
    include-all: true
    filter: '广美|美国|美國|USA|United States|America|(^|[^A-Z])US([^A-Z]|$)|纽约|波特兰|达拉斯|俄勒冈|凤凰城|费利蒙|硅谷|拉斯维加斯|洛杉矶|圣何塞|圣克拉拉|西雅图|芝加哥|🇺🇸'

  - name: 其他-自动
    type: url-test
    include-all: true
    filter: '澳大利亚|澳洲|Australia|英国|UK|United Kingdom|德国|Germany|法国|France|荷兰|Netherlands|加拿大|Canada|印度|India|越南|Vietnam|泰国|Thailand|俄罗斯|Russia|巴西|Brazil|西班牙|Spain|意大利|Italy|乌克兰|Ukraine|瑞士|Switzerland|瑞典|Sweden|挪威|Norway|芬兰|Finland|爱尔兰|Ireland|以色列|Israel|土耳其|Turkey|阿根廷|Argentina|印尼|Indonesia|马来西亚|Malaysia|菲律宾|Philippines|墨西哥|Mexico|Konghwaguk'
    url: http://www.gstatic.com/generate_204
    interval: 600

rule-providers:
  claude-fixed:
    behavior: classical
    format: text
